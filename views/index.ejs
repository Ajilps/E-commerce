<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bytez - Your Online Store</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style/user/homepage/homePage.css">
</head>

<body>
    <%- include('head.ejs') %>

        <!-- Hero Carousel -->
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"
                    aria-current="true" aria-label="New Season Arrivals"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"
                    aria-label="Special Summer Offers"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"
                    aria-label="Electronics Sale"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="/assets/productImg/androidphones-2048px-04371-2x1-1.webp" class="d-block w-100"
                        alt="New Season Arrivals" width="1200" height="400">
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100">
                        <div class="caption-content">
                            <h2 class="display-4 fw-bold d-none d-md-block">New Season Arrivals</h2>
                            <h3 class="fw-bold d-md-none">New Season Arrivals</h3>
                            <p class="d-none d-sm-block">Discover the latest trends and exclusive deals</p>
                            <a href="/user/store" class="btn btn-primary btn-lg mt-2 mt-md-3 px-4 py-md-2">Shop Now</a>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="/assets/productImg/androidphones-2048px-04371-2x1-1.webp" class="d-block w-100"
                        alt="Special Summer Offers" loading="lazy" width="1200" height="400">
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100">
                        <div class="caption-content">
                            <h2 class="display-4 fw-bold d-none d-md-block">Special Summer Offers</h2>
                            <h3 class="fw-bold d-md-none">Special Summer Offers</h3>
                            <p class="d-none d-sm-block">Up to 50% off on selected items</p>
                            <a href="/user/store" class="btn btn-primary btn-lg mt-2 mt-md-3 px-4 py-md-2">View
                                Deals</a>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="/assets/productImg/androidphones-2048px-04371-2x1-1.webp" class="d-block w-100"
                        alt="Electronics Sale" loading="lazy" width="1200" height="400">
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100">
                        <div class="caption-content">
                            <h2 class="display-4 fw-bold d-none d-md-block">Electronics Sale</h2>
                            <h3 class="fw-bold d-md-none">Electronics Sale</h3>
                            <p class="d-none d-sm-block">Latest gadgets at unbeatable prices</p>
                            <a href="/user/store" class="btn btn-primary btn-lg mt-2 mt-md-3 px-4 py-md-2">Explore
                                Now</a>
                        </div>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>

        <!-- New Arrivals Product Slider -->
        <%- include('user/partials/_productSlider', { title: 'New Arrivals Products' , linkText: 'See all offers' ,
            products: newArrivals }) %>

            <!-- Top Selling Product Slider -->
            <%- include('user/partials/_productSlider', { title: 'Top Selling Products' , linkText: 'See all offers' ,
                products: topProducts }) %>

                <%- include('footer.ejs') %>

                    <script src="/script/user/homePage/homePage.js"></script>
</body>

</html>