<section class="product-slider-section" aria-label="<%= title %>">
  <div class="product-slider-header">
    <h2 class="product-slider-title">
      <%= title %>
    </h2>
    <a href="/user/store" class="view-all-link">
      <%= linkText %>
    </a>
  </div>

  <div class="product-slider-container">
    <button class="nav-button prev-button" aria-label="Previous">&#10094;</button>

    <div class="product-slider-track">
      <% if (products && products.length> 0) { %>
        <% products.forEach(function(product) { %>
          <%- include('_productCard', { product }) %>
            <% }); %>
              <% } else { %>
                <p class="text-muted p-3">No products available.</p>
                <% } %>
    </div>

    <button class="nav-button next-button" aria-label="Next">&#10095;</button>
  </div>
</section>